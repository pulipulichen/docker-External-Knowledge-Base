[api]
# API_KEY: API key for external services
API_KEY="YOUR_API_KEY"

# USE_MOCK_DB: Set to true to use a mock database, false otherwise
USE_MOCK_DB=false

# For download link
URL_HOST=http://localhost:8080/f/

GEMINI_BASE_URL="https://generativelanguage.googleapis.com"
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
GEMINI_MODEL="gemini-flash-latest"

# Mercury Parser (used by POST /scrape): base URL of mercury-parser-api inside Docker network
MERCURY_PARSER_URL=http://mercury-parser:3000
# Request timeout in seconds when calling Mercury Parser
MERCURY_REQUEST_TIMEOUT=90

[searxng]
# SearXNG (used by POST /search): base URL inside Docker network
SEARXNG_URL=http://searxng:8080
# Request timeout in seconds when calling SearXNG
SEARXNG_REQUEST_TIMEOUT=30

# SearXNG 容器：對應官方 SEARXNG_SECRET（覆寫密鑰）。未設定時 docker-compose 使用預設字串（僅本機測試）。
# SEARXNG_SECRET=
SEARXNG_SECRET=ultrasecretkey2ultrasecretkey

[redis]
# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
CACHE_EXPIRATION_SECONDS=2592000

[weaviate]
WEAVIATE_HOST=weaviate
WEAVIATE_PORT=8080
WEAVIATE_URL=http://weaviate:8080

WEAVIATE_GRPC_PORT=50051

[embedding]
# Embedding engine: tei or gemini
EMBEDDING_ENGINE=gemini

GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_EMBEDDING_MODEL=gemini-embedding-2-preview
GEMINI_OUTPUT_DIMENSIONALITY=3072

[tei]
# TEI Embedding Service Configuration
TEI_ENDPOINT=http://tei:80
SERVICE_CHECK_INTERVAL=5
SERVICE_CHECK_TIMEOUT=1
